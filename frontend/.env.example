# Copy this file to .env.local for development, or set these variables
# in your hosting provider's dashboard (Vercel, Render, etc.) for production.
#
# NEXT_PUBLIC_* variables are baked into the client bundle at build time,
# so they must be present when `next build` runs.

# Base URL of the Spring Boot backend API.
# Dev example:  http://localhost:8080
# Prod example: https://your-api.example.com
NEXT_PUBLIC_API_URL=

# Google OAuth client ID (Web application). Public by design — Google checks
# the JavaScript origin on every request.
# Create one at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=
